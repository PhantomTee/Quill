# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Groq (AI description enhancement) ────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─── Arc Testnet / Smart Contract ─────────────────────────────────────────────
# Address of deployed AgentRegistry.sol on Arc Testnet
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...

# Private key for deploying contracts (hardhat scripts only, never expose)
DEPLOYER_PRIVATE_KEY=0x...

# Private key for the seller wallet (used by x402 middleware)
SELLER_PRIVATE_KEY=0x...

# Public seller address (receives USDC from agent calls)
NEXT_PUBLIC_SELLER_ADDRESS=0x...

# ─── Arc RPC (keyed Canteen endpoint — get with: arc-canteen rpc-url) ─────────
# Falls back to public rpc.testnet.arc.network if not set
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>

# ─── App URL ──────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron auth ────────────────────────────────────────────────────────────────
# Random secret to authenticate the GitHub Actions sync cron
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─── Autonomous buyer agent ────────────────────────────────────────────────────
# Private key for the server-side buyer wallet that pays agents autonomously
# Fund with testnet USDC before using /agent-run
# NEVER put this in the browser or client-side code
BUYER_PRIVATE_KEY=0x...
